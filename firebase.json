{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "node_modules/**",
      "android-cashier/**",
      "dist/**",
      "functions/**",
      "server.js",
      "package.json",
      "package-lock.json",
      "demo-state.json",
      "*.srt",
      "*.pdf",
      "*.apk",
      "orders*.json",
      "tableOrders*.json",
      "temp_script_*",
      "*_output.txt",
      "*_err.txt",
      "CLAUDE.md",
      "extracted.txt",
      "jsdom_logs.txt",
      "test_jsdom*",
      "firebase-debug.log"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
